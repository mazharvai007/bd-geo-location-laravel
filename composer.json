{
    "name": "mazharvai/bd-geo-location",
    "description": "Bangladesh Geo Location data package for Laravel with support for Divisions, Districts, Upazilas, and Unions",
    "keywords": [
        "laravel",
        "bangladesh",
        "geo-location",
        "location",
        "geography",
        "bd",
        "divisions",
        "districts",
        "upazilas",
        "unions"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "mazharvai",
            "email": "mazharvai007@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "larastan/larastan": "^2.0",
        "phpstan/phpstan": "^1.10"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-html=coverage/html",
        "analyse": "vendor/bin/phpstan analyse",
        "analyse:baseline": "vendor/bin/phpstan analyse --generate-baseline",
        "quality": [
            "@composer validate --strict",
            "@analyse"
        ],
        "ci": [
            "@quality",
            "@test"
        ]
    },
    "autoload": {
        "psr-4": {
            "Mazharvai\\BDGeoLocation\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Mazharvai\\BDGeoLocation\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mazharvai\\BDGeoLocation\\BDGeoServiceProvider"
            ],
            "aliases": {
                "BDGeo": "Mazharvai\\BDGeoLocation\\Facades\\BDGeo"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
